# Configuració de connexió a MongoDB Atlas
# Copia aquest fitxer a .env i omple amb les teves credencials

# URI de connexió a MongoDB Atlas (format: mongodb+srv://...)
# Substitueix <usuari>, <contrasenya> i <cluster> pels teus valors
MONGO_URI=mongodb+srv://<usuari>:<contrasenya>@<cluster>.mongodb.net

# Nom de la base de dades
MONGO_DB=feb_db
